<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  OpenClaw Gateway Watchdog — LaunchAgent plist
  
  This is a TEMPLATE. Run install-watchdog.sh to install with correct paths.
  Or manually replace __WORKSPACE_PATH__ with your workspace directory.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.clawconfig.watchdog</string>

    <key>ProgramArguments</key>
    <array>
        <string>__WORKSPACE_PATH__/tools/watchdog.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__HOME__/.openclaw/logs/claw-config-watchdog.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/.openclaw/logs/claw-config-watchdog.stderr.log</string>
</dict>
</plist>
